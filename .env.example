# ─── TELEGRAM ───────────────────────────────────────────────
# Get from @BotFather on Telegram — create a new bot
TELEGRAM_BOT_TOKEN=

# ─── SUPABASE ───────────────────────────────────────────────
# Get from Supabase project dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── CLAUDE API ─────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── GOOGLE PLACES API ──────────────────────────────────────
# Get from https://console.cloud.google.com → Enable Places API
GOOGLE_PLACES_API_KEY=

# ─── RESEND (EMAIL) ─────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@yourdomain.com

# ─── LANGFUSE (LLM TRACING) ─────────────────────────────────
# Get from https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── APP ────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=https://your-vercel-app.vercel.app

# ─── WEBHOOK ────────────────────────────────────────────────
# Dev: ngrok URL e.g. https://abc123.ngrok.io
# Staging/prod: your Vercel deployment URL
WEBHOOK_URL=https://your-vercel-app.vercel.app/api/telegram

# ─── CRON SECRET ────────────────────────────────────────────
# Random string — protects cron endpoints from unauthorised calls
CRON_SECRET=
